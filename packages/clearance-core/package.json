{
  "name": "@clearance/core",
  "version": "0.2.0",
  "description": "EIP-7702 based agent permission scoping",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/preflight-sh/preflight"
  },
  "keywords": [
    "ai-agent",
    "permissions",
    "eip-7702",
    "clearance",
    "evm",
    "blockchain"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
