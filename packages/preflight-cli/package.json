{
  "name": "@preflight/cli",
  "version": "0.2.0",
  "description": "CLI runner for preflight AI agent behavioral tests",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/preflight-sh/preflight"
  },
  "keywords": [
    "ai-agent",
    "testing",
    "cli",
    "evm",
    "preflight"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "preflight": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0"
  },
  "dependencies": {
    "@preflight/core": "workspace:*",
    "vitest": "^4.0.0"
  }
}
